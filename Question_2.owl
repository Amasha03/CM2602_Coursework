        <auto:requiresMaintenance rdf:resource="&auto;BeltSwap"/>
    </rdf:Description>

    <!-- Welding must meet quality and safety standards -->
    <rdf:Description rdf:about="&auto;SpotWelding">
        <auto:complyWith rdf:resource="&auto;ISO_TS16949"/>
        <auto:complyWith rdf:resource="&auto;ISO26262"/>
    </rdf:Description>

    <rdf:Description rdf:about="&auto;RoofWelding">
        <auto:complyWith rdf:resource="&auto;ISO9001"/>
        <auto:complyWith rdf:resource="&auto;ASIL-A"/>
    </rdf:Description>

    <!-- Assembly must comply with quality and functional safety standards -->
    <rdf:Description rdf:about="&auto;EngineMarriage">
        <auto:complyWith rdf:resource="&auto;ISO_TS16949"/>
        <auto:complyWith rdf:resource="&auto;ISO26262"/>
        <auto:complyWith rdf:resource="&auto;ASIL-B"/>
    </rdf:Description>

    <rdf:Description rdf:about="&auto;DashboardInstallation">
        <auto:complyWith rdf:resource="&auto;ISO9001"/>
        <auto:complyWith rdf:resource="&auto;ASIL-A"/>
    </rdf:Description>

    <!-- Inspection must comply with quality management standards -->
    <rdf:Description rdf:about="&auto;InlineLaserScan">
        <auto:complyWith rdf:resource="&auto;ISO_TS16949"/>
        <auto:complyWith rdf:resource="&auto;ISO9001"/>
    </rdf:Description>

    <rdf:Description rdf:about="&auto;GapAndFlushCheck">
        <auto:complyWith rdf:resource="&auto;ISO9001"/>
    </rdf:Description>

</rdf:RDF>
